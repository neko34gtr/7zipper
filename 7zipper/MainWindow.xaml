<Window x:Class="Zipper7.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="7zipper" Height="150" Width="150" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" MouseLeftButtonDown="Window_MouseLeftButtonDown"
        ShowInTaskbar="True">
    <Grid>
        <Border x:Name="DropZone" CornerRadius="15" Background="#CC222222" BorderBrush="#FF444444" BorderThickness="2"
                AllowDrop="True" Drop="OnDrop" DragOver="OnDragOver" DragLeave="OnDragLeave" DragEnter="OnDragEnter">
            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="終了" Click="ExitMenu_Click" />
                </ContextMenu>
            </Border.ContextMenu>
            <Grid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="ZIP" FontSize="40" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="DROPPER" FontSize="10" Foreground="#AAAAAA" HorizontalAlignment="Center" />
                </StackPanel>

                <Grid x:Name="SelectionGrid" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#EE444444" CornerRadius="13,0,0,13" Margin="1" BorderBrush="#FF666666" BorderThickness="0,0,1,0">
                        <TextBlock Text="個別" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                    </Border>
                    <Border Grid.Column="1" Background="#EE222222" CornerRadius="0,13,13,0" Margin="1">
                        <TextBlock Text="一括" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                    </Border>
                </Grid>

                <Button Content="⚙" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10"
                        Background="Transparent" Foreground="#888888" BorderThickness="0" FontSize="18"
                        Click="ConfigButton_Click" Cursor="Hand"/>
            </Grid>
        </Border>

        <Border x:Name="ConfigPanel" CornerRadius="15" Background="#EE333333" BorderBrush="#FF555555" BorderThickness="2"
                Visibility="Collapsed" Padding="15">
            <StackPanel>
                <TextBlock Text="圧縮オプション" Foreground="White" FontWeight="Bold" Margin="0,0,0,10" FontSize="14"/>

                <CheckBox x:Name="ChkUltra" Content="最高圧縮 (Ultra)" Foreground="White" Margin="0,3"/>
                <CheckBox x:Name="ChkThread" Content="マルチスレッドを使用" Foreground="White" Margin="0,3"/>
                <CheckBox x:Name="ChkTimestamp" Content="元のタイムスタンプを維持" Foreground="White" Margin="0,3"/>

                <TextBlock Text="出力形式" Foreground="#AAAAAA" FontSize="10" Margin="0,10,0,2"/>
                <ComboBox x:Name="ComboExt" SelectedIndex="0" Margin="0,0,0,15">
                    <ComboBoxItem Content=".zip"/>
                    <ComboBoxItem Content=".7z"/>
                </ComboBox>

                <Button Content="設定を保存して戻る" Click="ConfigClose_Click" 
                        Background="#FF444444" Foreground="White" Height="30" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>